# FastAPI Backend — Environment Variables
# Copy this file to .env, fill in your values, and NEVER commit .env to git.

# ────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT  (defaults shown)
# ────────────────────────────────────────────────────────────────────────────

# AI provider: "ollama" (local default) | "azure_openai" (cloud)
LLM_PROVIDER=ollama

# -- Ollama (active when LLM_PROVIDER=ollama) --------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
EMBED_MODEL=nomic-embed-text

# -- Qdrant vector database --------------------------------------------------
# Mode: "memory" (zero setup) | "docker" (Docker Compose) | "cloud" (Qdrant Cloud)
QDRANT_MODE=memory
QDRANT_URL=http://localhost:6333    # used when QDRANT_MODE=docker

# -- LiveAvatar --------------------------------------------------------------
# Leave empty to display canvas mock avatar (no API key needed for local dev)
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=default
# Session mode: FULL (recommended for text-driven TTS) | LITE | CUSTOM
LIVEAVATAR_SESSION_MODE=LITE
# Set to true to use sandbox credits during development
LIVEAVATAR_IS_SANDBOX=false

# -- CORS --------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000


# ────────────────────────────────────────────────────────────────────────────
# AZURE DEPLOYMENT  (uncomment and fill in for cloud runs)
# ────────────────────────────────────────────────────────────────────────────

# LLM_PROVIDER=azure_openai

# -- Azure OpenAI (active when LLM_PROVIDER=azure_openai) --------------------
# AZURE_OPENAI_ENDPOINT=https://aicv-prod-aoai.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# Leave blank on Azure Container Apps → uses Managed Identity (recommended):
# AZURE_OPENAI_API_KEY=

# -- Qdrant Cloud (active when QDRANT_MODE=cloud) ----------------------------
# QDRANT_MODE=cloud
# QDRANT_CLOUD_URL=https://your-cluster.azure.qdrant.io:6333
# QDRANT_CLOUD_API_KEY=your-qdrant-api-key

# -- CORS for production frontend --------------------------------------------
# ALLOWED_ORIGINS=https://aicv-prod-swa.azurestaticapps.net
